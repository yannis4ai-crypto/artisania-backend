PRODUCT_NAME=NOM_NON_TRANCHE
API_PORT=8000

DATABASE_URL=postgresql://localhost/artisania

# Identifiants Mailjet — même compte, partagé par les deux consommateurs :
# - web app (config.py / services/notifications) : auth lien magique
# - services/relances/cli.py (batch cron, lu via os.environ direct)
MAILJET_API_KEY=
MAILJET_API_SECRET=
MAILJET_SENDER_EMAIL=
# Optionnel, services/relances/mailjet_notifier.py uniquement (sinon
# retombe sur relances@artisia.fr — cf note PRODUCT_NAME dans BACKLOG.md).
MAILJET_FROM_EMAIL=

# Sinch — DEUX jeux de identifiants distincts, noms volontairement
# différents pour éviter toute collision de sens sur ce même fichier :
# web app (config.py) :
SINCH_API_TOKEN=
SINCH_SERVICE_PLAN_ID=
SINCH_SENDER_NUMBER=
# services/relances/sinch_notifier.py (lu via os.environ direct) :
# SINCH_API_KEY = Service Plan ID, SINCH_API_SECRET = API Token (Bearer).
SINCH_API_KEY=
SINCH_API_SECRET=
SINCH_SENDER=
SINCH_REGION=eu

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

GOOGLE_MAPS_API_KEY=

MAGIC_LINK_SECRET=
MAGIC_LINK_TTL_MINUTES=15
